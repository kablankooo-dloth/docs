{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mintlify Starter Kit",
  "colors": {
    "primary": "#ff6adf",
    "light": "#de5bff",
    "dark": "#540964"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ],
    "tabs": [
      {
        "tab": "Overview",
        "dropdowns": [
          {
            "dropdown": "Policies",
            "pages": [
              "privacy",
              "terms-of-service"
            ]
          },
          {
            "dropdown": "Information",
            "pages": [
              "overview",
              "license"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json"
      },
      {
        "tab": "Public Services",
        "pages": [
          "services",
          "building-your-own",
          "application"
        ]
      },
      {
        "tab": "Announcements",
        "pages": [
          "announcements",
          "old-announcements"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "href": "https://discord.gg/eN8cR5eqvg",
        "label": "Discord"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/eN8cR5eqvg"
    }
  },
  "fonts": {
    "family": "Montserrat"
  }
}
